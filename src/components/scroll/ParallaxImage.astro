---
interface Props {
  src: string;
  alt: string;
  speed?: number;
  class?: string;
}
const { src, alt, speed = 0.3, class: className = '' } = Astro.props;
---
<div class={`overflow-hidden ${className}`}>
  <img
    src={src}
    alt={alt}
    data-parallax={speed}
    loading="lazy"
    class="h-full w-full object-cover will-change-transform"
  />
</div>
